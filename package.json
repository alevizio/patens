{
	"name": "font-studio",
	"version": "1.5.0",
	"description": "A browser-based type design environment. Draw glyphs with pressure-sensitive strokes, trace to Bézier contours, ship OpenType fonts. SvelteKit + IndexedDB, no server required.",
	"author": "Alejandro Vizio",
	"license": "MIT",
	"homepage": "https://github.com/alevizio/font-studio#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alevizio/font-studio.git"
	},
	"bugs": {
		"url": "https://github.com/alevizio/font-studio/issues"
	},
	"keywords": [
		"font",
		"type-design",
		"opentype",
		"sveltekit",
		"variable-font",
		"glyph-editor"
	],
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"build:demo-fonts": "node scripts/build-demo-fonts.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"analyze": "ANALYZE=1 vite build",
		"profile": "node scripts/profile-cold-load.mjs"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.3.0",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^4.1.7",
		"eslint": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"satori": "^0.26.0",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.6",
		"svelte-eslint-parser": "^1.6.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.59.4",
		"vite": "^7.3.3",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"@lucide/svelte": "^1.16.0",
		"@vercel/blob": "^2.4.0",
		"canvas-confetti": "^1.9.4",
		"fflate": "^0.8.3",
		"fit-curve": "^0.2.0",
		"harfbuzzjs": "^1.2.0",
		"idb-keyval": "^6.2.2",
		"opentype.js": "^2.0.0",
		"partysocket": "^1.1.19",
		"perfect-freehand": "^1.2.3",
		"polygon-clipping": "^0.15.7",
		"woff2-encoder": "^2.0.0",
		"y-indexeddb": "^9.0.12",
		"y-partykit": "^0.0.33",
		"yjs": "^13.6.30"
	},
	"pnpm": {
		"supportedArchitectures": {
			"os": ["current", "linux"],
			"cpu": ["current", "x64"]
		}
	}
}
