{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"framework": "sveltekit",
	"redirects": [
		{
			"source": "/(.*)",
			"has": [{ "type": "host", "value": "patens.app" }],
			"destination": "https://patens.design/$1",
			"permanent": true
		},
		{
			"source": "/(.*)",
			"has": [{ "type": "host", "value": "patens.studio" }],
			"destination": "https://patens.design/$1",
			"permanent": true
		},
		{
			"source": "/(.*)",
			"has": [{ "type": "host", "value": "font-studio.vercel.app" }],
			"destination": "https://patens.design/$1",
			"permanent": true
		}
	],
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-store, must-revalidate, max-age=0"
				}
			]
		},
		{
			"source": "/_app/immutable/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
